{
    "name": "mailmug/phpunit",
    "version": "1.0.0",
    "description": "PHPUnit assertions for testing emails with MailMug SMTP Sandbox",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "phpunit/phpunit": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "MailMug\\PHPUnit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MailMug\\PHPUnit\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "symfony/mailer": "^8.1",
        "vlucas/phpdotenv": "^5.6"
    }
}
